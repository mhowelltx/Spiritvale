generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Village {
  id         String   @id @default(uuid())
  seed       String
  name       String
  day        Int      @default(0)
  year       Int      @default(0)
  season     String   @default("spring")
  population Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resources         ResourceState?
  cultureState      CultureState?
  events            EventRecord[]
  villagers         Villager[]
  households        Household[]
  kinshipLinks      KinshipLink[]
  relationshipEdges RelationshipEdge[]

  @@index([day])
}

model ResourceState {
  id                    String @id @default(uuid())
  villageId             String @unique
  food                  Float
  weatherHarsh          Float
  diseaseRisk           Float
  blessingDaysRemaining Int    @default(0)

  village Village @relation(fields: [villageId], references: [id], onDelete: Cascade)
}

model CultureState {
  id                 String @id @default(uuid())
  villageId          String @unique
  sharingNorm        Float  @default(0.6)
  punishmentSeverity Float  @default(0.4)
  outsiderTolerance  Float  @default(0.3)
  prestigeByAge      Float  @default(0.7)
  prestigeBySkill    Float  @default(0.5)
  ritualIntensity    Float  @default(0.4)
  spiritualFear      Float  @default(0.5)
  kinLoyaltyNorm     Float  @default(0.8)

  village Village @relation(fields: [villageId], references: [id], onDelete: Cascade)
}

model Household {
  id        String     @id @default(uuid())
  villageId String
  name      String

  village   Village    @relation(fields: [villageId], references: [id], onDelete: Cascade)
  villagers Villager[]

  @@index([villageId])
}

model Villager {
  id          String  @id @default(uuid())
  villageId   String
  householdId String?
  name        String
  sex         String
  ageInDays   Int
  lifeStage   String
  role        String
  traits      Json
  needs       Json    @default("{\"hunger\":0,\"safety\":0.7,\"belonging\":0.5,\"status\":0.5}")
  emotions    Json    @default("{\"fear\":0.1,\"grief\":0,\"hope\":0.5,\"anger\":0}")
  motives     Json    @default("[]")

  village   Village    @relation(fields: [villageId], references: [id], onDelete: Cascade)
  household Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)

  kinshipFrom      KinshipLink[]      @relation("KinshipFrom")
  kinshipTo        KinshipLink[]      @relation("KinshipTo")
  relationshipFrom RelationshipEdge[] @relation("RelationshipFrom")
  relationshipTo   RelationshipEdge[] @relation("RelationshipTo")

  @@index([villageId])
  @@index([householdId])
}

model KinshipLink {
  id             String @id @default(uuid())
  villageId      String
  fromVillagerId String
  toVillagerId   String
  kind           String
  certainty      Float  @default(1.0)

  village      Village  @relation(fields: [villageId], references: [id], onDelete: Cascade)
  fromVillager Villager @relation("KinshipFrom", fields: [fromVillagerId], references: [id], onDelete: Cascade)
  toVillager   Villager @relation("KinshipTo", fields: [toVillagerId], references: [id], onDelete: Cascade)

  @@index([villageId])
  @@index([fromVillagerId])
}

model RelationshipEdge {
  id                 String @id @default(uuid())
  villageId          String
  fromVillagerId     String
  toVillagerId       String
  type               String
  strength           Float  @default(0.5)
  trust              Float  @default(0.5)
  lastInteractionDay Int    @default(0)

  village      Village  @relation(fields: [villageId], references: [id], onDelete: Cascade)
  fromVillager Villager @relation("RelationshipFrom", fields: [fromVillagerId], references: [id], onDelete: Cascade)
  toVillager   Villager @relation("RelationshipTo", fields: [toVillagerId], references: [id], onDelete: Cascade)

  @@index([villageId])
  @@index([fromVillagerId])
}

model EventRecord {
  id        String   @id @default(uuid())
  villageId String
  day       Int
  type      String
  title     String
  facts     Json
  createdAt DateTime @default(now())

  village Village @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@index([villageId, day])
}
