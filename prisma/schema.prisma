generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Social Psychology Sandbox — new models
// ---------------------------------------------------------------------------

model Experiment {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  hypothesis  String   @default("")
  contextType String   @default("neutral")
  status      String   @default("setup") // setup | running | paused | completed
  tick        Int      @default(0)
  seed        String
  // Stored as JSON blobs — deserialized into typed interfaces in service layer
  personalityDistribution Json
  culture                 Json  // HofstedeCulture
  scheduledInterventions  Json  @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  groups       SocialGroup[]
  agents       Agent[]
  relationships RelationshipEdge[]
  events       EventRecord[]
  metrics      MetricSnapshot[]
  interventions InterventionRecord[]

  @@index([status])
}

model SocialGroup {
  id           String     @id @default(uuid())
  experimentId String
  label        String
  assignmentRule String   @default("random")
  inGroupBias  Float      @default(0.5)
  cohesionIndex Float     @default(0.0)
  statusRank   Float      @default(0.0)

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  agents     Agent[]

  @@index([experimentId])
}

model Agent {
  id           String  @id @default(uuid())
  experimentId String
  groupId      String?
  name         String
  sex          String
  ageInTicks   Int     @default(0)
  lifeStage    String  @default("adult")
  // BigFiveProfile stored as JSON
  personality  Json
  attachmentStyle String @default("secure")
  // AgentNeeds stored as JSON
  needs        Json
  // AgentAffect stored as JSON
  affect       Json
  statusScore  Float   @default(0.5)
  motives      Json    @default("[]")

  experiment Experiment  @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  group      SocialGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  relationshipFrom RelationshipEdge[] @relation("RelationshipFrom")
  relationshipTo   RelationshipEdge[] @relation("RelationshipTo")

  @@index([experimentId])
  @@index([groupId])
}

model RelationshipEdge {
  id                    String @id @default(uuid())
  experimentId          String
  fromAgentId           String
  toAgentId             String
  type                  String @default("social")
  strength              Float  @default(0.3)
  trust                 Float  @default(0.3)
  lastInteractionTick   Int    @default(0)

  experiment  Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  fromAgent   Agent      @relation("RelationshipFrom", fields: [fromAgentId], references: [id], onDelete: Cascade)
  toAgent     Agent      @relation("RelationshipTo", fields: [toAgentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
  @@index([fromAgentId])
  @@index([toAgentId])
}

model MetricSnapshot {
  id           String   @id @default(uuid())
  experimentId String
  tick         Int
  metrics      Json     // MetricSnapshot interface values
  createdAt    DateTime @default(now())

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId, tick])
}

model InterventionRecord {
  id            String   @id @default(uuid())
  experimentId  String
  tick          Int
  type          String
  targetGroupId String?
  targetAgentId String?
  magnitude     Float    @default(0.5)
  durationTicks Int      @default(1)
  remainingTicks Int     @default(0)
  params        Json     @default("{}")
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId, tick])
  @@index([experimentId, resolved])
}

model EventRecord {
  id           String   @id @default(uuid())
  experimentId String
  tick         Int
  type         String
  title        String
  facts        Json
  createdAt    DateTime @default(now())

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId, tick])
}

// ---------------------------------------------------------------------------
// Legacy models (kept for reference during transition — will be dropped in a
// follow-up migration once the new engine is validated)
// ---------------------------------------------------------------------------

model Village_legacy {
  id         String   @id @default(uuid())
  seed       String
  name       String
  day        Int      @default(0)
  year       Int      @default(0)
  season     String   @default("spring")
  population Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Villager_legacy {
  id          String  @id @default(uuid())
  villageId   String
  householdId String?
  name        String
  sex         String
  ageInDays   Int
  lifeStage   String
  role        String
  traits      Json
  needs       Json
  emotions    Json
  motives     Json    @default("[]")
}

model Household_legacy {
  id        String @id @default(uuid())
  villageId String
  name      String
}
